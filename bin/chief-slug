#!/usr/bin/env bash
# chief-slug ‚Äî output project slug and sanitized branch name
# Usage: source <(chief-slug)  ‚Üí sets SLUG and BRANCH variables
# Or:    chief-slug           ‚Üí prints SLUG=... and BRANCH=... lines
set -euo pipefail
SLUG=$(git remote get-url origin 2>/dev/null | sed 's|.*[:/]\([^/]*/[^/]*\)\.git$|\1|;s|.*[:/]\([^/]*/[^/]*\)$|\1|' | tr '/' '-')
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null | tr '/' '-')
echo "SLUG=$SLUG"
echo "BRANCH=$BRANCH"
