#!/usr/bin/env bash
# chief-review-read — read review log and config for dashboard
# Usage: chief-review-read
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval $("$SCRIPT_DIR/chief-slug" 2>/dev/null)
CHIEF_HOME="${CHIEF_HOME:-$HOME/.chief}"
cat "$CHIEF_HOME/projects/$SLUG/$BRANCH-reviews.jsonl" 2>/dev/null || echo "NO_REVIEWS"
echo "---CONFIG---"
"$SCRIPT_DIR/chief-config" get skip_eng_review 2>/dev/null || echo "false"
echo "---HEAD---"
git rev-parse --short HEAD 2>/dev/null || echo "unknown"
