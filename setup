#!/usr/bin/env bash
# chief setup — build browser binary + register all skills with Claude Code
set -e

if ! command -v bun >/dev/null 2>&1; then
  echo "Error: bun is required but not installed." >&2
  echo "Install it: curl -fsSL https://bun.sh/install | bash" >&2
  exit 1
fi

CHIEF_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$(dirname "$CHIEF_DIR")"
BROWSE_BIN="$CHIEF_DIR/browse/dist/browse"

ensure_playwright_browser() {
  (
    cd "$CHIEF_DIR"
    bun --eval 'import { chromium } from "playwright"; const browser = await chromium.launch(); await browser.close();'
  ) >/dev/null 2>&1
}

# 1. Build browse binary if needed (smart rebuild: stale sources, package.json, lock)
NEEDS_BUILD=0
if [ ! -x "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -n "$(find "$CHIEF_DIR/browse/src" -type f -newer "$BROWSE_BIN" -print -quit 2>/dev/null)" ]; then
  NEEDS_BUILD=1
elif [ "$CHIEF_DIR/package.json" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -f "$CHIEF_DIR/bun.lock" ] && [ "$CHIEF_DIR/bun.lock" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
fi

if [ "$NEEDS_BUILD" -eq 1 ]; then
  echo "Building browse binary..."
  (
    cd "$CHIEF_DIR"
    bun install
    bun run build
  )
  # Safety net: write .version if build script didn't (e.g., git not available during build)
  if [ ! -f "$CHIEF_DIR/browse/dist/.version" ]; then
    git -C "$CHIEF_DIR" rev-parse HEAD > "$CHIEF_DIR/browse/dist/.version" 2>/dev/null || true
  fi
fi

if [ ! -x "$BROWSE_BIN" ]; then
  echo "chief setup failed: browse binary missing at $BROWSE_BIN" >&2
  exit 1
fi

# 2. Ensure Playwright's Chromium is available
if ! ensure_playwright_browser; then
  echo "Installing Playwright Chromium..."
  (
    cd "$CHIEF_DIR"
    bunx playwright install chromium
  )
fi

if ! ensure_playwright_browser; then
  echo "chief setup failed: Playwright Chromium could not be launched" >&2
  exit 1
fi

# 3. Ensure ~/.chief global state directory exists
mkdir -p "$HOME/.chief/projects"

# 4. Only create skill symlinks if we're inside a .claude/skills directory
SKILLS_BASENAME="$(basename "$SKILLS_DIR")"
if [ "$SKILLS_BASENAME" = "skills" ]; then
  linked=()
  for skill_dir in "$CHIEF_DIR"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      # Skip node_modules
      [ "$skill_name" = "node_modules" ] && continue
      target="$SKILLS_DIR/$skill_name"
      # Create or update symlink; skip if a real file/directory exists
      if [ -L "$target" ] || [ ! -e "$target" ]; then
        ln -snf "chief/$skill_name" "$target"
        linked+=("$skill_name")
      fi
    fi
  done

  # 5. Update CLAUDE.md with chief section (idempotent)
  CLAUDE_DIR="$(dirname "$SKILLS_DIR")"
  CLAUDE_MD="$CLAUDE_DIR/CLAUDE.md"
  if ! grep -q "## chief" "$CLAUDE_MD" 2>/dev/null; then
    touch "$CLAUDE_MD"
    {
      printf '\n## chief\n'
      printf 'Use /browse from chief for all web browsing. Never use mcp__claude-in-chrome__* tools.\n'
      printf 'Available skills: /chief, /chief-init, /chief-push, /chief-cook, /office-hours,\n'
      printf '/plan-ceo-review, /plan-eng-review, /plan-design-review, /design-consultation,\n'
      printf '/review, /ship, /browse, /qa, /qa-only, /design-review, /setup-browser-cookies,\n'
      printf '/retro, /investigate, /document-release, /codex, /careful, /freeze, /guard,\n'
      printf '/unfreeze, /chief-upgrade.\n'
      printf 'If chief skills are not working, run: cd %s && ./setup\n' "$CHIEF_DIR"
    } >> "$CLAUDE_MD"
    echo "  updated: $CLAUDE_MD"
  fi

  echo "chief ready."
  echo "  browse: $BROWSE_BIN"
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi
else
  echo "chief ready."
  echo "  browse: $BROWSE_BIN"
  echo "  (skipped skill symlinks — not inside .claude/skills/)"
fi

# 4. First-time welcome + legacy cleanup
if [ ! -d "$HOME/.chief" ]; then
  mkdir -p "$HOME/.chief"
  echo "  Welcome! Run /chief-upgrade anytime to stay current."
fi
rm -f /tmp/chief-latest-version
